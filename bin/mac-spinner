#!/usr/bin/env bash
set -euo pipefail

self_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
repo_dir="$(cd -- "${self_dir}/.." && pwd -P)"

for candidate in \
  "${repo_dir}/.build/release/mac-spinner" \
  "${repo_dir}/.build/debug/mac-spinner"
do
  if [[ -x "$candidate" ]]; then
    exec "$candidate" "$@"
  fi
done

exec swift run --package-path "$repo_dir" mac-spinner "$@"

# it under the terms of the GNU Affero General Public License as published by
# the Free Software Foundation, either version 3 of the License, or
# (at your option) any later version.
#
# This program is distributed in the hope that it will be useful,
# but WITHOUT ANY WARRANTY; without even the implied warranty of
# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
# GNU Affero General Public License for more details.
#
# You should have received a copy of the GNU Affero General Public License
# along with this program.  If not, see <https://www.gnu.org/licenses/>.
#
# In accordance with section 13 of the AGPL, if you modify this program,
# your modified version must prominently offer all users interacting with it
# remotely through a computer network an opportunity to receive the source
# code of your version.
#
# USAGE:
#   mac-sync <command>
#
# COMMANDS:
#   install     Install or refresh mac-sync and its hourly LaunchAgent
#   bootstrap   Alias for install
#   uninstall   Unload the LaunchAgent and remove the installed command
#   sync        Sync configured paths, commit machine changes, and push
#   run         LaunchAgent mode; alias for sync
#   restore     Restore this machine snapshot back into $HOME
#   restore --from <machine> [--force]
#               Restore another machine snapshot back into $HOME
#   secrets     Manage encrypted secret snapshots with age and Keychain
#   list        Show configured source paths and repo destinations
#   paths       Alias for list
#   status      Show install, repo, LaunchAgent, git, and last-sync state
#   help [topic]
#               Show this help text or command-specific help
#   -h, --help  Show this help text
#
# ENVIRONMENT:
#   MAC_SYNC_REPO          mac-sync repo path. Default: $HOME/github/mac-sync
#   MAC_SYNC_MACHINES_REPO Machine snapshot repo. Default: $HOME/github/dot-files
#   MAC_SYNC_MACHINE       Machine directory name. Default: macOS host name
#   MAC_SYNC_INSTALL_PATH  Installed command. Default: $HOME/bin/mac-sync
#   MAC_SYNC_HOURLY_MINUTE LaunchAgent minute, 0-59. Default: 0
#   MAC_SYNC_DAILY_MINUTE  Legacy alias for MAC_SYNC_HOURLY_MINUTE
#   MAC_SYNC_LAUNCH_AGENT_PATH
#                          PATH used by the LaunchAgent
#   MAC_SYNC_STATUS_DIR    Local status directory
#   MAC_SYNC_DRY_RUN       Set to 1 to preview sync and restore actions
#   MAC_SYNC_DYNAMIC_REFS  Set to 0 to disable dotfile reference discovery
#   MAC_SYNC_HOMEBREW      Set to 0 to disable Homebrew package snapshots
#   MAC_SYNC_SECRETS       Set to 0 to disable encrypted secret snapshots
#   MAC_SYNC_KEYCHAIN_SERVICE
#                          Keychain service for the age identity
#   MAC_SYNC_KEYCHAIN_ACCOUNT
#                          Keychain account. Default: $USER or id -un
#   SCRIPT_COLOUR          Set to off, false, or 0 to disable colour
#
# EXAMPLES:
#   ./bin/mac-sync install
#   mac-sync list
#   mac-sync sync
#   mac-sync restore --from old-mbp
#   mac-sync secrets init
#   mac-sync secrets list --from old-mbp
#   mac-sync help restore
#   mac-sync help secrets
#   MAC_SYNC_MACHINE=work-mbp mac-sync install

set -euo pipefail

readonly SELF_PATH="${BASH_SOURCE[0]:-$0}"
SCRIPT_NAME="$(basename "$SELF_PATH")"
readonly SCRIPT_NAME
SELF_DIR="$(cd "$(dirname "$SELF_PATH")" 2>/dev/null && pwd -P || dirname "$SELF_PATH")"
readonly SELF_DIR
readonly HOME_DIR="${HOME:?HOME is not set}"
readonly DEFAULT_REPO_DIR="${HOME_DIR}/github/mac-sync"
readonly DEFAULT_MACHINES_REPO_DIR="${HOME_DIR}/github/dot-files"
readonly REPO_DIR="${MAC_SYNC_REPO:-$DEFAULT_REPO_DIR}"
readonly MACHINES_REPO_DIR="${MAC_SYNC_MACHINES_REPO:-$DEFAULT_MACHINES_REPO_DIR}"
readonly INSTALL_PATH="${MAC_SYNC_INSTALL_PATH:-${HOME_DIR}/bin/mac-sync}"
INSTALL_DIR="$(dirname "$INSTALL_PATH")"
readonly INSTALL_DIR
readonly SPINNER_INSTALL_PATH="${INSTALL_DIR}/mac-spinner"
readonly HOURLY_MINUTE="${MAC_SYNC_HOURLY_MINUTE:-${MAC_SYNC_DAILY_MINUTE:-0}}"
readonly LAUNCH_AGENT_PATH="${MAC_SYNC_LAUNCH_AGENT_PATH:-${HOME_DIR}/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin}"
readonly DRY_RUN="${MAC_SYNC_DRY_RUN:-0}"
readonly DYNAMIC_REFS="${MAC_SYNC_DYNAMIC_REFS:-1}"
readonly HOMEBREW_SYNC="${MAC_SYNC_HOMEBREW:-1}"
readonly SECRETS_SYNC="${MAC_SYNC_SECRETS:-1}"
readonly PATHS_FILE="${MAC_SYNC_PATHS_FILE:-${REPO_DIR}/config/sync-paths.txt}"
readonly EXCLUDES_FILE="${MAC_SYNC_EXCLUDES_FILE:-${REPO_DIR}/config/excludes.txt}"
readonly SECRET_PATHS_FILE="${MAC_SYNC_SECRET_PATHS_FILE:-${REPO_DIR}/config/secret-paths.txt}"
readonly AGE_RECIPIENTS_FILE="${MAC_SYNC_AGE_RECIPIENTS_FILE:-${REPO_DIR}/config/age-recipients.txt}"
readonly KEYCHAIN_SERVICE="${MAC_SYNC_KEYCHAIN_SERVICE:-mac-sync age identity}"
readonly KEYCHAIN_ACCOUNT="${MAC_SYNC_KEYCHAIN_ACCOUNT:-${USER:-$(id -un)}}"
readonly REPO_SCRIPT="${REPO_DIR}/bin/mac-sync"
readonly REPO_SPINNER="${REPO_DIR}/bin/mac-spinner"
readonly SELF_SPINNER="${SELF_DIR}/mac-spinner"
readonly LAUNCH_AGENT_LABEL="tools.xyzzy.mac-sync"
readonly LAUNCH_AGENT_PLIST="${HOME_DIR}/Library/LaunchAgents/${LAUNCH_AGENT_LABEL}.plist"
readonly LOG_OUT="/tmp/mac-sync.out"
readonly LOG_ERR="/tmp/mac-sync.err"

case "${SCRIPT_COLOUR:-}" in
  off|OFF|false|FALSE|0)
    readonly COLOUR_ENABLED=0
    ;;
  *)
    readonly COLOUR_ENABLED=1
    ;;
esac

if [[ -t 2 && "$COLOUR_ENABLED" = "1" ]]; then
  readonly COLOUR_ERROR=$'\033[31m'
  readonly COLOUR_WARN=$'\033[38;5;214m'
  readonly COLOUR_RESET=$'\033[0m'
else
  readonly COLOUR_ERROR=""
  readonly COLOUR_WARN=""
  readonly COLOUR_RESET=""
fi

if [[ -t 1 && "$COLOUR_ENABLED" = "1" ]]; then
  readonly COLOUR_HEADER=$'\033[33m'
  readonly COLOUR_HEADER_RESET=$'\033[0m'
else
  readonly COLOUR_HEADER=""
  readonly COLOUR_HEADER_RESET=""
fi

PROGRESS_HELPER_PID=""
PROGRESS_COMMAND_OUTPUT=""

MAC_SYNC_RUN_ACTIVE=0
MAC_SYNC_RUN_STARTED_AT=""
MAC_SYNC_RUN_STARTED_EPOCH=0
MAC_SYNC_RUN_WARNINGS_TMP=""
MAC_SYNC_RUN_ERRORS_TMP=""
MAC_SYNC_WARNING_COUNT=0
MAC_SYNC_ERROR_COUNT=0
MAC_SYNC_STARTED_FILE_COUNT=0
MAC_SYNC_STARTED_BYTE_COUNT=0
MAC_SYNC_LAST_UPDATED_FILE_COUNT=0
MAC_SYNC_LAST_UPDATED_BYTE_COUNT=0
MAC_SYNC_LAST_NET_BYTE_CHANGE=0
MAC_SYNC_LAST_STORAGE_FILE_COUNT=0
MAC_SYNC_LAST_STORAGE_BYTE_COUNT=0


# Print the embedded usage block from this script.
usage() {
  awk -v script_name="$SCRIPT_NAME" \
      -v header="$COLOUR_HEADER" \
      -v reset="$COLOUR_HEADER_RESET" '
    /^# USAGE:/ { inblock = 1 }
    inblock {
      if ($0 !~ /^#/) exit
      line = $0
      sub(/^#[ ]?/, "", line)
      gsub(/mac-sync/, script_name, line)
      if (line ~ /^[A-Z0-9][A-Z0-9 _-]*:$/) {
        printf "%s%s%s\n", header, line, reset
      } else {
        print line
      }
    }
  ' "$SELF_PATH"
}


# Print command-specific restore usage.
usage_restore() {
  cat <<EOF
USAGE:
  $SCRIPT_NAME restore [--from <machine>] [--force]

OPTIONS:
  --from <machine>  Restore from another machine snapshot. Default: current machine.
  --force           Overwrite newer local files and resolve file/directory conflicts.
  -h, --help        Show this help text.

BEHAVIOR:
  Restore pulls both repos first when their worktrees are clean.
  It restores configured paths plus that machine's persisted dynamic paths.
  Newer local files are kept unless --force is used.
  Homebrew differences are printed as manual brew commands.
  Encrypted secrets are not restored automatically; restore prints the secrets
  commands when an encrypted snapshot exists.

EXAMPLES:
  $SCRIPT_NAME restore
  $SCRIPT_NAME restore --from old-mbp
  $SCRIPT_NAME restore --from old-mbp --force
  MAC_SYNC_DRY_RUN=1 $SCRIPT_NAME restore --from old-mbp
EOF
}


# Print command-specific encrypted secrets usage.
usage_secrets() {
  cat <<EOF
USAGE:
  $SCRIPT_NAME secrets <command>

COMMANDS:
  init       Create or reuse this Mac's Keychain age identity
  sync       Update the encrypted secret snapshot and push machine state
  list       List files in an encrypted secret snapshot
  restore    Restore files from an encrypted secret snapshot
  test       Check Keychain identity and current archive decryption
  help       Show this help text

OPTIONS:
  list --from <machine>
  restore --from <machine> [--force]

NOTES:
  Private age identity is stored in Apple Keychain under the configured service.
  Public recipients are stored in config/age-recipients.txt.
  Secret paths are configured in config/secret-paths.txt.
  Normal restore never decrypts secrets automatically.

EXAMPLES:
  $SCRIPT_NAME secrets init
  $SCRIPT_NAME secrets sync
  $SCRIPT_NAME secrets list --from old-mbp
  $SCRIPT_NAME secrets restore --from old-mbp
  $SCRIPT_NAME secrets restore --from old-mbp --force
  $SCRIPT_NAME secrets test
EOF
}


# Dispatch top-level and command-specific help.
cmd_help() {
  local topic="${1:-}"

  if [[ "$#" -gt 1 ]]; then
    error "too many help arguments"
    usage >&2
    exit 2
  fi

  case "$topic" in
    "")
      usage
      ;;
    restore)
      usage_restore
      ;;
    secrets)
      usage_secrets
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      error "unknown help topic: $topic"
      usage >&2
      exit 2
      ;;
  esac
}


# Print a fatal error message to stderr.
error() {
  ((MAC_SYNC_ERROR_COUNT += 1))
  if [[ -n "$MAC_SYNC_RUN_ERRORS_TMP" ]]; then
    printf 'ERROR: %s\n' "$*" >>"$MAC_SYNC_RUN_ERRORS_TMP"
  fi

  printf '%sERROR%s: %s\n' "$COLOUR_ERROR" "$COLOUR_RESET" "$*" >&2
}


# Print a non-fatal warning to stderr.
warning() {
  ((MAC_SYNC_WARNING_COUNT += 1))
  if [[ -n "$MAC_SYNC_RUN_WARNINGS_TMP" ]]; then
    printf 'WARN: %s\n' "$*" >>"$MAC_SYNC_RUN_WARNINGS_TMP"
  fi

  printf '%sWARN%s: %s\n' "$COLOUR_WARN" "$COLOUR_RESET" "$*" >&2
}


# Print a human-facing informational message to stdout.
info() {
  printf '%s\n' "$*"
}


# Print the progress helper command to use when one is available.
progress_helper_path() {
  local path

  for path in "$SELF_SPINNER" "$REPO_SPINNER" "$SPINNER_INSTALL_PATH"; do
    if [[ -x "$path" ]]; then
      printf '%s\n' "$path"
      return 0
    fi
  done

  return 1
}


# Print a pending progress line to stdout.
progress_pending() {
  local spinner

  if spinner="$(progress_helper_path)"; then
    "$spinner" --message "$*" --pending
  else
    info "$*"
  fi
}


# Start in-place progress for an in-flight operation.
progress_start() {
  local message="$1"
  local spinner

  progress_stop
  if [[ ! -t 1 ]]; then
    progress_pending "$message"
  elif spinner="$(progress_helper_path)"; then
    "$spinner" --message "$message" --spin-only &
    PROGRESS_HELPER_PID="$!"
  else
    progress_pending "$message"
  fi
}


# Stop the active progress helper.
progress_stop() {
  local pid="${PROGRESS_HELPER_PID:-}"

  if [[ -z "$pid" ]]; then
    return 0
  fi

  kill "$pid" >/dev/null 2>&1 || true
  wait "$pid" 2>/dev/null || true
  PROGRESS_HELPER_PID=""
}


# Print a completed progress line to stdout.
progress_done() {
  local spinner

  progress_stop
  if spinner="$(progress_helper_path)"; then
    "$spinner" --message "$*" --done
  else
    info "$*"
  fi
}


# Run a command while showing progress and capturing combined output.
run_with_spinner() {
  local message="$1"
  local output_file
  local spinner
  local status=0
  shift

  output_file="$(mktemp "${TMPDIR:-/tmp}/mac-sync-command.XXXXXX")"
  PROGRESS_COMMAND_OUTPUT=""
  if spinner="$(progress_helper_path)" && ! declare -F "$1" >/dev/null 2>&1; then
    "$spinner" --message "$message" --output "$output_file" -- "$@" || status=$?
  else
    progress_start "$message"
    "$@" >"$output_file" 2>&1 || status=$?
    progress_stop
  fi
  PROGRESS_COMMAND_OUTPUT="$(cat "$output_file")"
  rm -f -- "$output_file"

  return "$status"
}


# Print output captured by the last spinner command, when there is any.
print_progress_command_output() {
  [[ -n "$PROGRESS_COMMAND_OUTPUT" ]] || return 0
  printf '%s\n' "$PROGRESS_COMMAND_OUTPUT" >&2
}


# Return a timestamp suitable for log-file entries.
ts() {
  date '+%Y-%m-%d %H:%M:%S'
}


# Append a message to the standard output log.
log() {
  printf '[%s] %s\n' "$(ts)" "$*" >>"$LOG_OUT"
}


# Release the sync lock when this process owns it.
release_lock() {
  local pid_file="${LOCK_DIR}/pid"
  local lock_pid=""

  if [[ -f "$pid_file" ]]; then
    lock_pid="$(cat "$pid_file" 2>/dev/null || true)"
  fi

  if [[ "$lock_pid" = "$$" ]]; then
    rm -rf "$LOCK_DIR"
  fi
}


# Prevent overlapping hourly sync runs.
acquire_lock() {
  local pid_file="${LOCK_DIR}/pid"
  local lock_pid=""

  if mkdir "$LOCK_DIR" 2>/dev/null; then
    printf '%s\n' "$$" >"$pid_file"
    return 0
  fi

  if [[ -f "$pid_file" ]]; then
    lock_pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
      info "another mac-sync run is active; exiting: pid $lock_pid"
      exit 0
    fi
  fi

  warning "removing stale sync lock: $LOCK_DIR"
  rm -rf "$LOCK_DIR"
  mkdir "$LOCK_DIR"
  printf '%s\n' "$$" >"$pid_file"
}


# Ensure a required command is available.
need() {
  command -v "$1" >/dev/null 2>&1 || {
    error "missing required command: $1"
    exit 1
  }
}


# Ensure an integer value falls inside a closed range.
validate_int_range() {
  local name="$1"
  local value="$2"
  local min="$3"
  local max="$4"

  case "$value" in
    ""|*[!0-9]*)
      error "$name must be an integer from $min to $max"
      exit 2
      ;;
  esac

  if (( 10#$value < min || 10#$value > max )); then
    error "$name must be an integer from $min to $max"
    exit 2
  fi
}


# Return the physical path for an existing file or directory.
realpath_existing() {
  local path="$1"
  local dir
  local base

  if [[ -d "$path" ]]; then
    (cd "$path" && pwd -P)
    return 0
  fi

  dir="$(dirname "$path")"
  base="$(basename "$path")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
    return 0
  fi

  printf '%s\n' "$path"
}


# Escape XML special characters for LaunchAgent values.
xmlescape() {
  local value="$1"

  value=${value//&/&amp;}
  value=${value//</&lt;}
  value=${value//>/&gt;}
  value=${value//\"/&quot;}
  value=${value//\'/&apos;}

  printf '%s' "$value"
}


# Return a stable, filesystem-safe machine name.
machine_name() {
  local raw="${MAC_SYNC_MACHINE:-}"

  if [[ -z "$raw" ]] && command -v scutil >/dev/null 2>&1; then
    raw="$(scutil --get LocalHostName 2>/dev/null || true)"
  fi

  if [[ -z "$raw" ]] && command -v scutil >/dev/null 2>&1; then
    raw="$(scutil --get ComputerName 2>/dev/null || true)"
  fi

  if [[ -z "$raw" ]]; then
    raw="$(hostname -s 2>/dev/null || hostname)"
  fi

  printf '%s\n' "$raw" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//'
}


MACHINE_NAME="$(machine_name)"
readonly MACHINE_NAME
readonly MACHINES_ROOT_DIR="${MACHINES_REPO_DIR}/machines"
readonly MACHINE_DIR="${MACHINES_ROOT_DIR}/${MACHINE_NAME}"
readonly MACHINE_HOME_DIR="${MACHINE_DIR}/home"
readonly MACHINE_ABSOLUTE_DIR="${MACHINE_DIR}/absolute"
readonly DYNAMIC_PATHS_FILE="${MACHINE_DIR}/dynamic-sync-paths.txt"
readonly HOMEBREW_DIR="${MACHINE_DIR}/homebrew"
readonly SECRETS_DIR="${MACHINE_DIR}/secrets"
readonly SECRETS_ARCHIVE="${SECRETS_DIR}/secrets.tar.gz.age"
readonly SECRETS_INCLUDED_PATHS_FILE="${SECRETS_DIR}/included-paths.txt"
readonly LOCK_DIR="${TMPDIR:-/tmp}/mac-sync-${MACHINE_NAME}.lock"
readonly STATUS_DIR="${MAC_SYNC_STATUS_DIR:-${HOME_DIR}/Library/Application Support/mac-sync/status}"
readonly SYNC_STATUS_FILE="${STATUS_DIR}/${MACHINE_NAME}.env"
readonly SYNC_WARNINGS_FILE="${STATUS_DIR}/${MACHINE_NAME}.warnings.log"
readonly SYNC_ERRORS_FILE="${STATUS_DIR}/${MACHINE_NAME}.errors.log"

MAC_SYNC_KEYGEN_TMP_DIR=""
MAC_SYNC_ARCHIVE_TMP_DIR=""
MAC_SYNC_SECRET_IDENTITY_TMP=""
MAC_SYNC_SECRET_CONFLICTS_TMP=""
MAC_SYNC_SECRET_ENTRIES_TMP=""
MAC_SYNC_SYNC_TMP_CONFIGURED=""
MAC_SYNC_SYNC_TMP_DYNAMIC=""
MAC_SYNC_SYNC_TMP_DYNAMIC_EXTRA=""
MAC_SYNC_SYNC_TMP_MANIFEST=""


# Remove the temporary age-keygen workspace.
cleanup_keygen_tmp_dir() {
  if [[ -n "$MAC_SYNC_KEYGEN_TMP_DIR" ]]; then
    rm -rf -- "$MAC_SYNC_KEYGEN_TMP_DIR"
    MAC_SYNC_KEYGEN_TMP_DIR=""
  fi
}


# Remove the temporary encrypted archive workspace.
cleanup_archive_tmp_dir() {
  if [[ -n "$MAC_SYNC_ARCHIVE_TMP_DIR" ]]; then
    rm -rf -- "$MAC_SYNC_ARCHIVE_TMP_DIR"
    MAC_SYNC_ARCHIVE_TMP_DIR=""
  fi
}


# Remove the temporary age identity file.
cleanup_secret_identity_tmp() {
  if [[ -n "$MAC_SYNC_SECRET_IDENTITY_TMP" ]]; then
    rm -f -- "$MAC_SYNC_SECRET_IDENTITY_TMP"
    MAC_SYNC_SECRET_IDENTITY_TMP=""
  fi
}


# Remove temporary files used during encrypted secret restore.
cleanup_secret_restore_tmps() {
  if [[ -n "$MAC_SYNC_SECRET_CONFLICTS_TMP" ]]; then
    rm -f -- "$MAC_SYNC_SECRET_CONFLICTS_TMP"
    MAC_SYNC_SECRET_CONFLICTS_TMP=""
  fi

  if [[ -n "$MAC_SYNC_SECRET_ENTRIES_TMP" ]]; then
    rm -f -- "$MAC_SYNC_SECRET_ENTRIES_TMP"
    MAC_SYNC_SECRET_ENTRIES_TMP=""
  fi

  cleanup_secret_identity_tmp
}


# Remove temporary files used during normal sync.
cleanup_sync_tmps() {
  if [[ -n "$MAC_SYNC_SYNC_TMP_CONFIGURED" ]]; then
    rm -f -- "$MAC_SYNC_SYNC_TMP_CONFIGURED"
    MAC_SYNC_SYNC_TMP_CONFIGURED=""
  fi

  if [[ -n "$MAC_SYNC_SYNC_TMP_DYNAMIC" ]]; then
    rm -f -- "$MAC_SYNC_SYNC_TMP_DYNAMIC"
    MAC_SYNC_SYNC_TMP_DYNAMIC=""
  fi

  if [[ -n "$MAC_SYNC_SYNC_TMP_DYNAMIC_EXTRA" ]]; then
    rm -f -- "$MAC_SYNC_SYNC_TMP_DYNAMIC_EXTRA"
    MAC_SYNC_SYNC_TMP_DYNAMIC_EXTRA=""
  fi

  if [[ -n "$MAC_SYNC_SYNC_TMP_MANIFEST" ]]; then
    rm -f -- "$MAC_SYNC_SYNC_TMP_MANIFEST"
    MAC_SYNC_SYNC_TMP_MANIFEST=""
  fi
}


# Return a timestamp for local status output.
status_timestamp() {
  date '+%Y-%m-%d %H:%M:%S %Z'
}


# Return the size of one file in bytes.
file_size_bytes() {
  local file="$1"
  local size

  size="$(wc -c <"$file" | tr -d '[:space:]')"
  printf '%s\n' "${size:-0}"
}


# Count regular files below a directory.
tree_file_count() {
  local dir="$1"
  local count

  if [[ ! -d "$dir" ]]; then
    printf '0\n'
    return 0
  fi

  count="$(find "$dir" -type f -print | wc -l | tr -d '[:space:]')"
  printf '%s\n' "${count:-0}"
}


# Sum regular-file bytes below a directory.
tree_byte_count() {
  local dir="$1"
  local total

  if [[ ! -d "$dir" ]]; then
    printf '0\n'
    return 0
  fi

  if stat -f '%z' "$SELF_PATH" >/dev/null 2>&1; then
    total="$(find "$dir" -type f -exec stat -f '%z' {} + \
      | awk '{ total += $1 } END { print total + 0 }')"
  elif stat -c '%s' "$SELF_PATH" >/dev/null 2>&1; then
    total="$(find "$dir" -type f -exec stat -c '%s' {} + \
      | awk '{ total += $1 } END { print total + 0 }')"
  else
    local file
    local size

    total=0
    while IFS= read -r -d '' file; do
      size="$(file_size_bytes "$file")"
      ((total += size)) || true
    done < <(find "$dir" -type f -print0)
  fi

  printf '%s\n' "${total:-0}"
}


# Print changed machine snapshot file count and current byte total.
changed_machine_metrics() {
  local rel_path
  local abs_path
  local size
  local count=0
  local total=0

  while IFS= read -r -d '' rel_path; do
    [[ -n "$rel_path" ]] || continue
    ((count += 1))
    abs_path="${MACHINES_REPO_DIR}/${rel_path}"
    if [[ -f "$abs_path" ]]; then
      size="$(file_size_bytes "$abs_path")"
      ((total += size)) || true
    fi
  done < <(
    git -C "$MACHINES_REPO_DIR" ls-files \
      --modified \
      --deleted \
      --others \
      --exclude-standard \
      -z \
      -- "machines/${MACHINE_NAME}"
  )

  printf '%s %s\n' "$count" "$total"
}


# Start recording local status for a sync run.
start_sync_status() {
  mkdir -p "$STATUS_DIR"

  MAC_SYNC_RUN_ACTIVE=1
  MAC_SYNC_RUN_STARTED_AT="$(status_timestamp)"
  MAC_SYNC_RUN_STARTED_EPOCH="$(date '+%s')"
  MAC_SYNC_WARNING_COUNT=0
  MAC_SYNC_ERROR_COUNT=0
  MAC_SYNC_STARTED_FILE_COUNT=0
  MAC_SYNC_STARTED_BYTE_COUNT=0
  MAC_SYNC_LAST_UPDATED_FILE_COUNT=0
  MAC_SYNC_LAST_UPDATED_BYTE_COUNT=0
  MAC_SYNC_LAST_NET_BYTE_CHANGE=0
  MAC_SYNC_LAST_STORAGE_FILE_COUNT=0
  MAC_SYNC_LAST_STORAGE_BYTE_COUNT=0
  MAC_SYNC_RUN_WARNINGS_TMP="$(mktemp "${STATUS_DIR}/${MACHINE_NAME}.warnings.XXXXXX")"
  MAC_SYNC_RUN_ERRORS_TMP="$(mktemp "${STATUS_DIR}/${MACHINE_NAME}.errors.XXXXXX")"
}


# Capture the machine snapshot size before local sync changes.
capture_sync_start_metrics() {
  MAC_SYNC_STARTED_FILE_COUNT="$(tree_file_count "$MACHINE_DIR")"
  MAC_SYNC_STARTED_BYTE_COUNT="$(tree_byte_count "$MACHINE_DIR")"
}


# Capture the machine snapshot update and storage metrics.
capture_sync_finish_metrics() {
  local metrics

  MAC_SYNC_LAST_STORAGE_FILE_COUNT="$(tree_file_count "$MACHINE_DIR")"
  MAC_SYNC_LAST_STORAGE_BYTE_COUNT="$(tree_byte_count "$MACHINE_DIR")"
  ((MAC_SYNC_LAST_NET_BYTE_CHANGE = MAC_SYNC_LAST_STORAGE_BYTE_COUNT - MAC_SYNC_STARTED_BYTE_COUNT)) || true

  metrics="$(changed_machine_metrics)"
  read -r MAC_SYNC_LAST_UPDATED_FILE_COUNT MAC_SYNC_LAST_UPDATED_BYTE_COUNT <<<"$metrics"
}


# Persist local status for the last sync run.
finish_sync_status() {
  local status="$1"
  local duration=0
  local finished_at
  local finished_epoch
  local last_commit
  local remote_repo
  local result
  local tmp_status

  if [[ "$MAC_SYNC_RUN_ACTIVE" != "1" ]]; then
    return 0
  fi

  finished_at="$(status_timestamp)"
  finished_epoch="$(date '+%s')"
  if (( MAC_SYNC_RUN_STARTED_EPOCH > 0 )); then
    ((duration = finished_epoch - MAC_SYNC_RUN_STARTED_EPOCH)) || true
  fi

  if [[ "$status" = "0" ]]; then
    result="success"
  else
    result="failed"
  fi

  mkdir -p "$STATUS_DIR"
  if [[ -n "$MAC_SYNC_RUN_WARNINGS_TMP" && -f "$MAC_SYNC_RUN_WARNINGS_TMP" ]]; then
    mv "$MAC_SYNC_RUN_WARNINGS_TMP" "$SYNC_WARNINGS_FILE"
  else
    : >"$SYNC_WARNINGS_FILE"
  fi
  if [[ -n "$MAC_SYNC_RUN_ERRORS_TMP" && -f "$MAC_SYNC_RUN_ERRORS_TMP" ]]; then
    mv "$MAC_SYNC_RUN_ERRORS_TMP" "$SYNC_ERRORS_FILE"
  else
    : >"$SYNC_ERRORS_FILE"
  fi

  last_commit="$(git -C "$MACHINES_REPO_DIR" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
  remote_repo="$(git -C "$MACHINES_REPO_DIR" remote get-url origin 2>/dev/null || printf 'none')"
  tmp_status="$(mktemp "${STATUS_DIR}/${MACHINE_NAME}.env.XXXXXX")"
  {
    printf 'machine=%s\n' "$MACHINE_NAME"
    printf 'result=%s\n' "$result"
    printf 'exit_status=%s\n' "$status"
    printf 'started_at=%s\n' "$MAC_SYNC_RUN_STARTED_AT"
    printf 'finished_at=%s\n' "$finished_at"
    printf 'duration_seconds=%s\n' "$duration"
    printf 'started_file_count=%s\n' "$MAC_SYNC_STARTED_FILE_COUNT"
    printf 'started_byte_count=%s\n' "$MAC_SYNC_STARTED_BYTE_COUNT"
    printf 'updated_file_count=%s\n' "$MAC_SYNC_LAST_UPDATED_FILE_COUNT"
    printf 'updated_byte_count=%s\n' "$MAC_SYNC_LAST_UPDATED_BYTE_COUNT"
    printf 'net_byte_change=%s\n' "$MAC_SYNC_LAST_NET_BYTE_CHANGE"
    printf 'storage_file_count=%s\n' "$MAC_SYNC_LAST_STORAGE_FILE_COUNT"
    printf 'storage_byte_count=%s\n' "$MAC_SYNC_LAST_STORAGE_BYTE_COUNT"
    printf 'warning_count=%s\n' "$MAC_SYNC_WARNING_COUNT"
    printf 'error_count=%s\n' "$MAC_SYNC_ERROR_COUNT"
    printf 'remote_repo=%s\n' "$remote_repo"
    printf 'last_commit=%s\n' "$last_commit"
  } >"$tmp_status"
  mv "$tmp_status" "$SYNC_STATUS_FILE"

  MAC_SYNC_RUN_ACTIVE=0
  MAC_SYNC_RUN_WARNINGS_TMP=""
  MAC_SYNC_RUN_ERRORS_TMP=""
}


# Return true when the current LaunchAgent is loaded.
launchagent_loaded() {
  launchctl print "gui/$(id -u)/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1
}


# Return true when the repo has an origin remote.
repo_has_origin() {
  local repo="${1:-$REPO_DIR}"

  git -C "$repo" remote get-url origin >/dev/null 2>&1
}


# Return true when the repo worktree is clean.
repo_clean() {
  local repo="${1:-$REPO_DIR}"

  [[ -z "$(git -C "$repo" status --porcelain)" ]]
}


# Return true when the current branch has an upstream branch.
branch_has_upstream() {
  local repo="${1:-$REPO_DIR}"

  git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1
}


# Return true when the current branch has commits not present upstream.
branch_ahead_of_upstream() {
  local repo="${1:-$REPO_DIR}"
  local ahead_count

  branch_has_upstream "$repo" || return 1
  ahead_count="$(git -C "$repo" rev-list --count '@{u}..HEAD' 2>/dev/null || printf '0')"

  [[ "$ahead_count" != "0" ]]
}


# Return true when dynamic reference discovery is enabled.
dynamic_refs_enabled() {
  case "$DYNAMIC_REFS" in
    0|off|OFF|false|FALSE)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}


# Return true when Homebrew package snapshotting is enabled.
homebrew_sync_enabled() {
  case "$HOMEBREW_SYNC" in
    0|off|OFF|false|FALSE)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}


# Return true when encrypted secret snapshotting is enabled.
secrets_sync_enabled() {
  case "$SECRETS_SYNC" in
    0|off|OFF|false|FALSE)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}


# Return true when an array already contains a value.
array_contains() {
  local needle="$1"
  local item
  shift || true

  for item in "$@"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done

  return 1
}


# Print configured manifest paths without dynamic reference discovery.
configured_manifest_paths() {
  if [[ ! -f "$PATHS_FILE" ]]; then
    error "missing paths file: $PATHS_FILE"
    exit 1
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      ""|\#*)
        continue
        ;;
    esac
    printf '%s\n' "$line"
  done <"$PATHS_FILE"
}


# Print previously persisted dynamic manifest paths.
stored_dynamic_manifest_paths() {
  local dynamic_paths_file="${1:-$DYNAMIC_PATHS_FILE}"

  if [[ ! -f "$dynamic_paths_file" ]]; then
    return 0
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      ""|\#*)
        continue
        ;;
    esac
    printf '%s\n' "$line"
  done <"$dynamic_paths_file"
}


# Return true when a path is equal to or nested under another path.
paths_overlap() {
  local left="$1"
  local right="$2"

  [[ "$left" == "$right" || "$left" == "$right"/* || "$right" == "$left"/* ]]
}


# Return true when a path overlaps any path listed in a file.
path_overlaps_file() {
  local rel="$1"
  local file="$2"
  local item

  [[ -f "$file" ]] || return 1

  while IFS= read -r item || [[ -n "$item" ]]; do
    case "$item" in
      ""|\#*)
        continue
        ;;
    esac
    if paths_overlap "$rel" "$item"; then
      return 0
    fi
  done <"$file"

  return 1
}


# Return a HOME-relative path for a path inside HOME.
home_relative_path() {
  local path="$1"

  case "$path" in
    "$HOME_DIR"/*)
      path="${path#"$HOME_DIR"/}"
      ;;
    *)
      return 1
      ;;
  esac

  path="${path#./}"
  path="${path%/}"

  [[ -n "$path" ]] || return 1
  printf '%s\n' "$path"
}


# Return true when a dynamically discovered path is safe to snapshot.
safe_dynamic_rel_path() {
  local rel="$1"

  case "$rel" in
    ""|/*|../*|*/../*|.)
      return 1
      ;;
  esac

  case "$rel" in
    .*|bin/*|Library/Application\ Support/Code/User/*)
      ;;
    *)
      return 1
      ;;
  esac

  case "$rel" in
    .CFUserTextEncoding|.DS_Store|.bash_history|.zsh_history|.viminfo|.vault-pass|.zcompdump*)
      return 1
      ;;
    .cache|.cache/*|.local|.local/*|.Trash|.Trash/*)
      return 1
      ;;
    .cargo/bin|.cargo/bin/*|.colima/_lima|.colima/_lima/*)
      return 1
      ;;
    .secrets|.secrets/*|.codex-secrets|.codex-secrets/*)
      return 1
      ;;
    .aws/credentials|.config/ansible/vault.pass|.config/argocd/config|.config/gh/hosts.yml)
      return 1
      ;;
    .docker/config.json|.git-credentials|.kube/config|.netrc|.npmrc|.pypirc|.gem/credentials)
      return 1
      ;;
    .codex/auth.json|.codex/installation_id)
      return 1
      ;;
    .gnupg/*)
      [[ "$rel" == ".gnupg/common.conf" ]] || return 1
      ;;
    .ssh/*)
      case "$rel" in
        .ssh/config|.ssh/*.pub)
          ;;
        *)
          return 1
          ;;
      esac
      ;;
    *.pem|*.ppk|*.p12|*.pfx|*.key)
      return 1
      ;;
  esac

  return 0
}


# Choose the sync root for a dynamically discovered reference.
dynamic_sync_root_for() {
  local rel="$1"
  local first
  local second
  local third

  IFS=/ read -r first second third _ <<<"$rel"

  case "$rel" in
    .config/*/*|.zsh/*/*)
      printf '%s/%s\n' "$first" "$second"
      ;;
    .tmux/plugins/*/*)
      printf '%s/%s/%s\n' "$first" "$second" "$third"
      ;;
    *)
      printf '%s\n' "$rel"
      ;;
  esac
}


# Return true when a file is safe to inspect as text.
is_text_file() {
  local file="$1"

  [[ -f "$file" ]] || return 1
  [[ ! -s "$file" ]] || LC_ALL=C grep -Iq . "$file" 2>/dev/null
}


# Print HOME path references found in one text file.
extract_reference_candidates() {
  local file="$1"

  awk -v home="$HOME_DIR" '
    {
      line = $0
      if (line !~ /shellcheck[[:space:]]+source=/) {
        sub(/[[:space:]]+#.*$/, "", line)
      }
      gsub(/\$\{HOME\}/, home, line)
      gsub(/\$HOME/, home, line)
      gsub(/~/, home, line)

      if (match(line, /for[[:space:]]+shell_config[[:space:]]+in[[:space:]]+[^;]+/)) {
        shell_configs = substr(line, RSTART, RLENGTH)
        sub(/^for[[:space:]]+shell_config[[:space:]]+in[[:space:]]+/, "", shell_configs)
        split(shell_configs, names, /[[:space:]]+/)
        for (name in names) {
          if (names[name] ~ /^[A-Za-z0-9_-]+$/) {
            print home "/." names[name]
          }
        }
      }

      pattern = home "/(\\.|bin/|Library/Application Support/Code/User/)[^\"\047[:space:];|<>)]*"
      while (match(line, pattern)) {
        path = substr(line, RSTART, RLENGTH)
        sub(/[,:]+$/, "", path)
        print path
        line = substr(line, RSTART + RLENGTH)
      }
    }
  ' "$file"
}


# Print safe top-level home dotfiles to use as dynamic scan roots.
dynamic_home_dotfiles() {
  local path
  local rel

  while IFS= read -r path; do
    rel="$(home_relative_path "$path")" || continue
    safe_dynamic_rel_path "$rel" || continue
    printf '%s\n' "$path"
  done < <(find "$HOME_DIR" -maxdepth 1 -type f -name '.*' -print | LC_ALL=C sort)
}


# Print safe paths discovered from home dotfile references.
dynamic_manifest_paths() {
  local -a discovered=()
  local -a scan_queue=()
  local -a seen_files=()
  local i=0
  local path
  local ref
  local ref_src
  local rel
  local scan_file
  local sync_rel

  dynamic_refs_enabled || return 0

  while IFS= read -r path; do
    scan_queue+=("$path")
  done < <(dynamic_home_dotfiles)

  while (( i < ${#scan_queue[@]} )); do
    scan_file="${scan_queue[$i]}"
    ((i += 1))

    if (( ${#seen_files[@]} > 0 )) && array_contains "$scan_file" "${seen_files[@]}"; then
      continue
    fi
    seen_files+=("$scan_file")

    is_text_file "$scan_file" || continue

    while IFS= read -r ref; do
      rel="$(home_relative_path "$ref")" || continue
      safe_dynamic_rel_path "$rel" || continue

      sync_rel="$(dynamic_sync_root_for "$rel")"
      safe_dynamic_rel_path "$sync_rel" || continue
      [[ -e "$(source_path_for "$sync_rel")" ]] || continue

      if (( ${#discovered[@]} == 0 )) || ! array_contains "$sync_rel" "${discovered[@]}"; then
        discovered+=("$sync_rel")
      fi

      ref_src="$(source_path_for "$rel")"
      if [[ -f "$ref_src" ]] \
        && { (( ${#scan_queue[@]} == 0 )) || ! array_contains "$ref_src" "${scan_queue[@]}"; }; then
        scan_queue+=("$ref_src")
      fi
    done < <(extract_reference_candidates "$scan_file")
  done

  if (( ${#discovered[@]} > 0 )); then
    printf '%s\n' "${discovered[@]}"
  fi
}


# Persist the generated dynamic manifest for auditing and stale-path pruning.
write_dynamic_paths_manifest() {
  local current_dynamic_file="$1"

  mkdir -p "$MACHINE_DIR"
  {
    printf '%s\n' '# Generated by mac-sync. Do not edit.'
    printf '%s\n' '# HOME-relative dynamic paths discovered from dotfile references.'
    cat "$current_dynamic_file"
  } >"$DYNAMIC_PATHS_FILE"
}


# Print dynamic paths that are not already covered by the curated manifest.
dynamic_extra_paths() {
  local current_dynamic_file="$1"
  local configured_paths_file="$2"
  local rel

  while IFS= read -r rel || [[ -n "$rel" ]]; do
    safe_dynamic_rel_path "$rel" || continue
    path_overlaps_file "$rel" "$configured_paths_file" && continue
    printf '%s\n' "$rel"
  done <"$current_dynamic_file"
}


# Remove old dynamic snapshot paths that are no longer discovered.
prune_stale_dynamic_paths() {
  local current_dynamic_file="$1"
  local configured_paths_file="$2"
  local dest
  local rel

  dynamic_refs_enabled || return 0
  [[ -f "$DYNAMIC_PATHS_FILE" ]] || return 0

  while IFS= read -r rel; do
    safe_dynamic_rel_path "$rel" || continue
    path_overlaps_file "$rel" "$current_dynamic_file" && continue
    path_overlaps_file "$rel" "$configured_paths_file" && continue

    dest="$(dest_path_for "$rel")"
    if [[ -e "$dest" || -L "$dest" ]]; then
      if [[ "$DRY_RUN" = "1" ]]; then
        info "would remove stale dynamic snapshot: $dest"
      else
        rm -rf "$dest"
        info "removed stale dynamic snapshot: $dest"
      fi
    fi
  done < <(stored_dynamic_manifest_paths)
}


# Print one normalized manifest path per line.
manifest_paths() {
  {
    configured_manifest_paths
    dynamic_manifest_paths
  } | awk 'NF && !seen[$0]++'
}


# Convert a manifest path to a source path under HOME or an absolute path.
source_path_for() {
  local rel="$1"

  case "$rel" in
    /*)
      printf '%s\n' "$rel"
      ;;
    *)
      printf '%s/%s\n' "$HOME_DIR" "$rel"
      ;;
  esac
}


# Convert a manifest path to the destination path inside the machine snapshot.
dest_path_for() {
  local rel="$1"

  case "$rel" in
    /*)
      printf '%s%s\n' "$MACHINE_ABSOLUTE_DIR" "$rel"
      ;;
    *)
      printf '%s/%s\n' "$MACHINE_HOME_DIR" "$rel"
      ;;
  esac
}


# Convert a manifest path to a source path inside a machine snapshot.
snapshot_path_for() {
  local machine="$1"
  local rel="$2"
  local machine_dir="${MACHINES_ROOT_DIR}/${machine}"

  case "$rel" in
    /*)
      printf '%s/absolute%s\n' "$machine_dir" "$rel"
      ;;
    *)
      printf '%s/home/%s\n' "$machine_dir" "$rel"
      ;;
  esac
}


# Return true when a machine argument is safe to use as a repo path segment.
safe_machine_name() {
  local machine="$1"

  case "$machine" in
    ""|*[!A-Za-z0-9._-]*)
      return 1
      ;;
  esac

  return 0
}


# Print the restore manifest for a source machine snapshot.
restore_manifest_paths() {
  local machine="$1"
  local dynamic_paths_file="${MACHINES_ROOT_DIR}/${machine}/dynamic-sync-paths.txt"

  {
    configured_manifest_paths
    stored_dynamic_manifest_paths "$dynamic_paths_file"
  } | awk 'NF && !seen[$0]++'
}


# Return the Homebrew snapshot directory for a machine.
homebrew_dir_for() {
  local machine="$1"

  printf '%s/%s/homebrew\n' "$MACHINES_ROOT_DIR" "$machine"
}


# Print non-comment package names from a Homebrew snapshot list.
homebrew_list_file_lines() {
  local file="$1"
  local line

  [[ -f "$file" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      ""|\#*)
        continue
        ;;
    esac
    printf '%s\n' "$line"
  done <"$file"
}


# Write a generated Homebrew snapshot list with stable ordering.
write_homebrew_list_file() {
  local target="$1"
  local description="$2"
  local producer="$3"

  {
    printf '%s\n' '# Generated by mac-sync. Do not edit.'
    printf '# %s\n' "$description"
    "$producer" | awk 'NF' | LC_ALL=C sort -u
  } >"$target"
}


# Print installed Homebrew taps.
homebrew_taps() {
  brew tap 2>/dev/null || true
}


# Print installed Homebrew formulae.
homebrew_formulae() {
  brew list --formula -1 2>/dev/null || true
}


# Print installed Homebrew casks.
homebrew_casks() {
  brew list --cask -1 2>/dev/null || true
}


# Print outdated installed Homebrew formulae.
homebrew_outdated_formulae() {
  brew outdated --formula --quiet 2>/dev/null || true
}


# Print outdated installed Homebrew casks.
homebrew_outdated_casks() {
  brew outdated --cask --quiet 2>/dev/null || true
}


# Escape a value for the generated Brewfile.
brewfile_quote() {
  local value="$1"

  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  printf '%s' "$value"
}


# Write a Brewfile view of the generated Homebrew package lists.
write_homebrew_brewfile() {
  local homebrew_dir="$1"
  local line

  {
    printf '%s\n' '# Generated by mac-sync. Do not edit.'
    while IFS= read -r line; do
      printf 'tap "%s"\n' "$(brewfile_quote "$line")"
    done < <(homebrew_list_file_lines "${homebrew_dir}/taps.txt")
    while IFS= read -r line; do
      printf 'brew "%s"\n' "$(brewfile_quote "$line")"
    done < <(homebrew_list_file_lines "${homebrew_dir}/formulae.txt")
    while IFS= read -r line; do
      printf 'cask "%s"\n' "$(brewfile_quote "$line")"
    done < <(homebrew_list_file_lines "${homebrew_dir}/casks.txt")
  } >"${homebrew_dir}/Brewfile"
}


# Write the complete local Homebrew package snapshot.
write_homebrew_snapshot() {
  mkdir -p "$HOMEBREW_DIR"
  write_homebrew_list_file "$HOMEBREW_DIR/taps.txt" "Installed Homebrew taps." homebrew_taps
  write_homebrew_list_file "$HOMEBREW_DIR/formulae.txt" "Installed Homebrew formulae." homebrew_formulae
  write_homebrew_list_file "$HOMEBREW_DIR/casks.txt" "Installed Homebrew casks." homebrew_casks
  write_homebrew_brewfile "$HOMEBREW_DIR"
}


# Sync the local Homebrew package state into the machine snapshot.
sync_homebrew_packages() {
  homebrew_sync_enabled || return 0

  if ! command -v brew >/dev/null 2>&1; then
    warning "Homebrew not found; skipping Homebrew package snapshot"
    return 0
  fi

  if [[ "$DRY_RUN" = "1" ]]; then
    progress_pending "would update Homebrew package snapshot: $HOMEBREW_DIR"
    return 0
  fi

  if ! run_with_spinner "updating Homebrew package snapshot" write_homebrew_snapshot; then
    print_progress_command_output
    return 1
  fi
  progress_done "updated Homebrew package snapshot: $HOMEBREW_DIR"
}


# Print a file's package list sorted and deduplicated.
sort_homebrew_list_file() {
  local source_file="$1"
  local target_file="$2"

  homebrew_list_file_lines "$source_file" | LC_ALL=C sort -u >"$target_file"
}


# Print the current local Homebrew package list for a category.
current_homebrew_list() {
  local kind="$1"

  command -v brew >/dev/null 2>&1 || return 0

  case "$kind" in
    taps)
      homebrew_taps
      ;;
    formulae)
      homebrew_formulae
      ;;
    casks)
      homebrew_casks
      ;;
    outdated-formulae)
      homebrew_outdated_formulae
      ;;
    outdated-casks)
      homebrew_outdated_casks
      ;;
  esac | awk 'NF' | LC_ALL=C sort -u
}


# Return a shell-safe representation of a Homebrew token.
shell_quote() {
  local value="$1"

  case "$value" in
    ""|*[!A-Za-z0-9_./:@%+=,-]*)
      printf "'"
      printf '%s' "$value" | sed "s/'/'\\\\''/g"
      printf "'"
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}


# Print one brew command for every item in a list file.
print_brew_command() {
  local prefix="$1"
  local file="$2"
  local command_text="  ${prefix}"
  local line
  local quoted
  local has_items=0

  [[ -s "$file" ]] || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" ]] || continue
    quoted="$(shell_quote "$line")"
    command_text="${command_text} ${quoted}"
    has_items=1
  done <"$file"

  if [[ "$has_items" = "1" ]]; then
    info "$command_text"
    return 0
  fi

  return 1
}


# Print manual brew commands needed to match a machine snapshot.
print_homebrew_restore_commands() {
  local machine="$1"
  local homebrew_dir
  local tmp_dir

  homebrew_sync_enabled || return 0

  homebrew_dir="$(homebrew_dir_for "$machine")"
  if [[ ! -f "$homebrew_dir/taps.txt" \
    && ! -f "$homebrew_dir/formulae.txt" \
    && ! -f "$homebrew_dir/casks.txt" ]]; then
    return 0
  fi

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/mac-sync-homebrew.XXXXXX")"

  sort_homebrew_list_file "$homebrew_dir/taps.txt" "$tmp_dir/desired-taps"
  sort_homebrew_list_file "$homebrew_dir/formulae.txt" "$tmp_dir/desired-formulae"
  sort_homebrew_list_file "$homebrew_dir/casks.txt" "$tmp_dir/desired-casks"
  current_homebrew_list taps >"$tmp_dir/current-taps"
  current_homebrew_list formulae >"$tmp_dir/current-formulae"
  current_homebrew_list casks >"$tmp_dir/current-casks"
  current_homebrew_list outdated-formulae >"$tmp_dir/outdated-formulae"
  current_homebrew_list outdated-casks >"$tmp_dir/outdated-casks"

  comm -23 "$tmp_dir/desired-taps" "$tmp_dir/current-taps" >"$tmp_dir/missing-taps"
  comm -23 "$tmp_dir/desired-formulae" "$tmp_dir/current-formulae" >"$tmp_dir/missing-formulae"
  comm -23 "$tmp_dir/desired-casks" "$tmp_dir/current-casks" >"$tmp_dir/missing-casks"
  comm -12 "$tmp_dir/desired-formulae" "$tmp_dir/outdated-formulae" >"$tmp_dir/upgrade-formulae"
  comm -12 "$tmp_dir/desired-casks" "$tmp_dir/outdated-casks" >"$tmp_dir/upgrade-casks"

  if [[ ! -s "$tmp_dir/missing-taps" \
    && ! -s "$tmp_dir/missing-formulae" \
    && ! -s "$tmp_dir/missing-casks" \
    && ! -s "$tmp_dir/upgrade-formulae" \
    && ! -s "$tmp_dir/upgrade-casks" ]]; then
    rm -rf "$tmp_dir"
    return 0
  fi

  if ! command -v brew >/dev/null 2>&1; then
    warning "Homebrew not found; install Homebrew before running these commands"
  fi

  printf '\n'
  info "Homebrew packages differ from the ${machine} snapshot."
  info "Run these commands manually:"
  info "  brew update"
  print_brew_command "brew tap" "$tmp_dir/missing-taps" || true
  print_brew_command "brew install" "$tmp_dir/missing-formulae" || true
  print_brew_command "brew install --cask" "$tmp_dir/missing-casks" || true
  print_brew_command "brew upgrade" "$tmp_dir/upgrade-formulae" || true
  print_brew_command "brew upgrade --cask" "$tmp_dir/upgrade-casks" || true

  rm -rf "$tmp_dir"
  return 0
}


# Return the encrypted secrets snapshot directory for a machine.
secrets_dir_for() {
  local machine="$1"

  printf '%s/%s/secrets\n' "$MACHINES_ROOT_DIR" "$machine"
}


# Return the encrypted secrets archive for a machine.
secrets_archive_for() {
  local machine="$1"

  printf '%s/secrets.tar.gz.age\n' "$(secrets_dir_for "$machine")"
}


# Return true when a secret path is safe to pass to tar as HOME-relative input.
safe_secret_rel_path() {
  local rel="$1"

  case "$rel" in
    ""|/*|..|../*|*/../*|*/..|.|-*)
      return 1
      ;;
  esac

  return 0
}


# Print configured secret paths.
secret_manifest_paths() {
  local line

  [[ -f "$SECRET_PATHS_FILE" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      ""|\#*)
        continue
        ;;
    esac
    if safe_secret_rel_path "$line"; then
      printf '%s\n' "$line"
    else
      warning "skip unsafe secret path: $line"
    fi
  done <"$SECRET_PATHS_FILE"
}


# Print configured age recipients.
age_recipients() {
  local line

  [[ -f "$AGE_RECIPIENTS_FILE" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      ""|\#*)
        continue
        ;;
    esac
    printf '%s\n' "$line"
  done <"$AGE_RECIPIENTS_FILE"
}


# Return true when at least one age recipient is configured.
age_recipients_present() {
  [[ -n "$(age_recipients | sed -n '1p')" ]]
}


# Append a unique non-secret line to a config file, preserving comments.
append_unique_config_line() {
  local file="$1"
  local line="$2"

  mkdir -p "$(dirname "$file")"
  touch "$file"
  if ! grep -Fx "$line" "$file" >/dev/null 2>&1; then
    printf '%s\n' "$line" >>"$file"
  fi
}


# Ensure the default secret path manifest exists.
ensure_secret_paths_file() {
  if [[ -f "$SECRET_PATHS_FILE" ]]; then
    return 0
  fi

  mkdir -p "$(dirname "$SECRET_PATHS_FILE")"
  {
    printf '%s\n' "# Paths are relative to \$HOME and are encrypted before syncing."
    printf '%s\n' "# Keep this list narrow; the decrypted archive restores into \$HOME."
    printf '%s\n' '.ssh'
    printf '%s\n' '.secrets'
  } >"$SECRET_PATHS_FILE"
}


# Ensure the age recipients file exists.
ensure_age_recipients_file() {
  if [[ -f "$AGE_RECIPIENTS_FILE" ]]; then
    return 0
  fi

  mkdir -p "$(dirname "$AGE_RECIPIENTS_FILE")"
  {
    printf '%s\n' '# Public age recipients that can decrypt encrypted secret snapshots.'
    printf '%s\n' '# Add one age1... recipient per trusted Mac or recovery key.'
  } >"$AGE_RECIPIENTS_FILE"
}


# Ensure tools needed for encrypted secrets are available.
check_secrets_runtime() {
  need age
  need gzip
  need gtar
}


# Ensure tools needed for Keychain-backed secret identity operations are available.
check_keychain_runtime() {
  check_secrets_runtime
  need age-keygen
  need security
}


# Return true when the Keychain age identity exists.
keychain_identity_exists() {
  security find-generic-password \
    -a "$KEYCHAIN_ACCOUNT" \
    -s "$KEYCHAIN_SERVICE" \
    -w >/dev/null 2>&1
}


# Ensure the Keychain age identity exists before a decrypt operation.
require_keychain_identity() {
  if keychain_identity_exists; then
    return 0
  fi

  error "missing Keychain age identity: $KEYCHAIN_SERVICE"
  error "run: $SCRIPT_NAME secrets init"
  exit 1
}


# Write the Keychain age identity to a temporary identity file.
write_keychain_identity_file() {
  local target="$1"
  local old_umask

  old_umask="$(umask)"
  umask 077
  security find-generic-password \
    -a "$KEYCHAIN_ACCOUNT" \
    -s "$KEYCHAIN_SERVICE" \
    -w >"$target"
  umask "$old_umask"
  chmod 600 "$target"
}


# Store an age identity in Apple Keychain.
store_keychain_identity() {
  local identity="$1"

  security add-generic-password \
    -a "$KEYCHAIN_ACCOUNT" \
    -s "$KEYCHAIN_SERVICE" \
    -w "$identity" \
    -U >/dev/null
}


# Return the public recipient for an age identity file.
recipient_from_identity_file() {
  local identity_file="$1"

  age-keygen -y "$identity_file"
}


# Return true when a recipient is present in the configured recipients file.
recipient_configured() {
  local recipient="$1"

  [[ -f "$AGE_RECIPIENTS_FILE" ]] || return 1
  grep -Fx "$recipient" "$AGE_RECIPIENTS_FILE" >/dev/null 2>&1
}


# Create or reuse the Keychain age identity and persist its public recipient.
cmd_secrets_init() {
  local tmp_dir
  local tmp_identity
  local tmp_keygen
  local identity
  local recipient

  check_runtime
  pull_repo_if_safe
  check_keychain_runtime

  ensure_secret_paths_file
  ensure_age_recipients_file

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/mac-sync-age-keygen.XXXXXX")"
  chmod 700 "$tmp_dir"
  tmp_identity="${tmp_dir}/identity.txt"
  tmp_keygen="${tmp_dir}/keygen.txt"
  MAC_SYNC_KEYGEN_TMP_DIR="$tmp_dir"
  trap 'cleanup_keygen_tmp_dir' EXIT INT TERM

  if keychain_identity_exists; then
    write_keychain_identity_file "$tmp_identity"
    recipient="$(recipient_from_identity_file "$tmp_identity")"
    info "Keychain age identity already exists: $KEYCHAIN_SERVICE"
  else
    age-keygen -o "$tmp_keygen" >/dev/null
    identity="$(awk '/^AGE-SECRET-KEY-/ { print; exit }' "$tmp_keygen")"
    if [[ -z "$identity" ]]; then
      error "age-keygen did not create an age identity"
      exit 1
    fi
    printf '%s\n' "$identity" >"$tmp_identity"
    recipient="$(recipient_from_identity_file "$tmp_identity")"
    store_keychain_identity "$identity"
    info "Stored new age identity in Apple Keychain: $KEYCHAIN_SERVICE"
  fi

  append_unique_config_line "$AGE_RECIPIENTS_FILE" "$recipient"
  if recipient_configured "$recipient"; then
    info "Configured public age recipient: $recipient"
  fi

  cleanup_keygen_tmp_dir
  trap - EXIT INT TERM

  commit_config_and_push \
    "chore: configure encrypted secrets" \
    "config/secret-paths.txt" \
    "config/age-recipients.txt"
}


# Commit selected config paths when they changed and push when useful.
commit_config_and_push() {
  local commit_message="$1"
  local branch
  local committed=0
  shift

  if [[ "$DRY_RUN" = "1" ]]; then
    info "dry run enabled; skipping config commit and push"
    return 0
  fi

  git -C "$REPO_DIR" add -- "$@"

  if git -C "$REPO_DIR" diff --cached --quiet -- "$@"; then
    info "no secrets config changes to commit"
  else
    git -C "$REPO_DIR" commit -m "$commit_message" -- "$@"
    committed=1
  fi

  if ! repo_has_origin; then
    warning "no origin remote configured; skipping git push"
    return 0
  fi

  branch="$(git -C "$REPO_DIR" branch --show-current)"
  if [[ -z "$branch" ]]; then
    warning "detached HEAD; skipping git push"
    return 0
  fi

  if [[ "$committed" = "1" ]] || branch_ahead_of_upstream; then
    info "pushing ${branch} to origin"
    git -C "$REPO_DIR" push -u origin "$branch"
  else
    info "no local commits to push"
  fi
}


# Write the plaintext included-paths manifest for an encrypted secrets snapshot.
write_secrets_included_paths_manifest() {
  local included_file="$1"

  mkdir -p "$SECRETS_DIR"
  {
    printf '%s\n' '# Generated by mac-sync. Do not edit.'
    printf '%s\n' '# HOME-relative paths included in secrets.tar.gz.age.'
    cat "$included_file"
  } >"$SECRETS_INCLUDED_PATHS_FILE"
}


# Write the current secret paths to a deterministic tar.gz archive.
write_plain_secrets_archive() {
  local included_file="$1"
  local target="$2"

  gtar -C "$HOME_DIR" \
    --ignore-failed-read \
    --warning=no-file-ignored \
    --sort=name \
    --exclude='.DS_Store' \
    --exclude='*/.DS_Store' \
    --exclude='*.sock' \
    --exclude='*.socket' \
    --exclude='.ssh/agent' \
    --exclude='.ssh/agent/*' \
    -cf - \
    -T "$included_file" \
    | gzip -n >"$target"
}


# Sync configured secret paths into an encrypted machine snapshot.
sync_secrets_archive() {
  local mode="${1:-auto}"
  local tmp_dir
  local tmp_included
  local tmp_archive
  local tmp_existing_archive
  local tmp_identity
  local tmp_plain_archive
  local rel
  local src

  secrets_sync_enabled || return 0

  if ! age_recipients_present; then
    if [[ "$mode" = "required" ]]; then
      error "no age recipients configured; run: $SCRIPT_NAME secrets init"
      exit 1
    fi
    return 0
  fi

  if [[ "$mode" = "required" ]]; then
    check_keychain_runtime
    require_keychain_identity
  elif ! command -v security >/dev/null 2>&1 || ! keychain_identity_exists; then
    warning "missing local Keychain age identity; skipping encrypted secrets snapshot"
    return 0
  fi

  if ! command -v age >/dev/null 2>&1 \
    || ! command -v gzip >/dev/null 2>&1 \
    || ! command -v gtar >/dev/null 2>&1; then
    if [[ "$mode" = "required" ]]; then
      check_secrets_runtime
    fi
    warning "age, gzip, or gtar not found; skipping encrypted secrets snapshot"
    return 0
  fi

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/mac-sync-secrets.XXXXXX")"
  tmp_included="${tmp_dir}/included-paths.txt"
  tmp_archive="${tmp_dir}/secrets.tar.gz.age"
  tmp_existing_archive="${tmp_dir}/existing-secrets.tar.gz"
  tmp_identity="${tmp_dir}/identity.txt"
  tmp_plain_archive="${tmp_dir}/secrets.tar.gz"
  MAC_SYNC_ARCHIVE_TMP_DIR="$tmp_dir"
  trap 'cleanup_archive_tmp_dir' RETURN

  while IFS= read -r rel; do
    src="$(source_path_for "$rel")"
    if [[ -e "$src" || -L "$src" ]]; then
      printf '%s\n' "$rel" >>"$tmp_included"
    elif [[ "$mode" = "required" ]]; then
      info "skip missing secret source: $src"
    fi
  done < <(secret_manifest_paths)

  if [[ ! -s "$tmp_included" ]]; then
    if [[ "$mode" = "required" ]]; then
      warning "no configured secret paths exist; skipping encrypted secrets snapshot"
    fi
    cleanup_archive_tmp_dir
    trap - RETURN
    return 0
  fi

  if [[ "$DRY_RUN" = "1" ]]; then
    progress_pending "would update encrypted secrets snapshot: $SECRETS_ARCHIVE"
    cleanup_archive_tmp_dir
    trap - RETURN
    return 0
  fi

  progress_start "updating encrypted secrets snapshot"
  mkdir -p "$SECRETS_DIR"
  write_plain_secrets_archive "$tmp_included" "$tmp_plain_archive"

  if [[ -f "$SECRETS_ARCHIVE" ]]; then
    write_keychain_identity_file "$tmp_identity"
    if age -d -i "$tmp_identity" "$SECRETS_ARCHIVE" >"$tmp_existing_archive"; then
      if cmp -s "$tmp_plain_archive" "$tmp_existing_archive"; then
        progress_done "encrypted secrets snapshot unchanged"
        cleanup_archive_tmp_dir
        trap - RETURN
        return 0
      fi
    else
      warning "could not decrypt existing encrypted secrets snapshot; rewriting it"
    fi
  fi

  age -R "$AGE_RECIPIENTS_FILE" -o "$tmp_archive" <"$tmp_plain_archive"
  mv "$tmp_archive" "$SECRETS_ARCHIVE"
  write_secrets_included_paths_manifest "$tmp_included"
  progress_done "updated encrypted secrets snapshot: $SECRETS_ARCHIVE"

  cleanup_archive_tmp_dir
  trap - RETURN
}


# Return true when a tar entry is safe to restore under HOME.
safe_archive_entry() {
  local entry="$1"

  case "$entry" in
    ""|/*|..|../*|*/../*|*/..|.)
      return 1
      ;;
  esac

  return 0
}


# Validate all archive entries before extraction.
validate_archive_entries() {
  local entries_file="$1"
  local entry

  while IFS= read -r entry || [[ -n "$entry" ]]; do
    safe_archive_entry "$entry" || {
      error "unsafe archive entry: $entry"
      exit 1
    }
  done <"$entries_file"
}


# Print archive entries that would overwrite existing local files.
secret_restore_conflicts() {
  local entries_file="$1"
  local entry
  local dest

  while IFS= read -r entry || [[ -n "$entry" ]]; do
    case "$entry" in
      */)
        continue
        ;;
    esac
    dest="$(source_path_for "$entry")"
    if [[ -e "$dest" || -L "$dest" ]]; then
      printf '%s\n' "$entry"
    fi
  done <"$entries_file"
}


# Write decrypted archive entry names to a file.
write_secret_archive_entries() {
  local archive="$1"
  local identity_file="$2"
  local entries_file="$3"

  age -d -i "$identity_file" "$archive" | gtar -tzf - >"$entries_file"
}


# Print an encrypted secrets restore hint during normal restore.
print_secrets_restore_hint() {
  local machine="$1"
  local archive

  secrets_sync_enabled || return 0

  archive="$(secrets_archive_for "$machine")"
  [[ -f "$archive" ]] || return 0

  printf '\n'
  info "Encrypted secrets snapshot found:"
  info "  $archive"
  info "To inspect it:"
  info "  $SCRIPT_NAME secrets list --from $(shell_quote "$machine")"
  info "To restore it:"
  info "  $SCRIPT_NAME secrets restore --from $(shell_quote "$machine")"
}


# List files in an encrypted secrets archive.
cmd_secrets_list() {
  local from_machine="$MACHINE_NAME"
  local archive
  local tmp_identity

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --from)
        if [[ "$#" -lt 2 ]]; then
          error "missing machine name after --from"
          exit 2
        fi
        from_machine="$2"
        shift 2
        ;;
      *)
        error "unknown secrets list option: $1"
        exit 2
        ;;
    esac
  done

  safe_machine_name "$from_machine" || {
    error "invalid machine name: $from_machine"
    exit 2
  }

  check_runtime
  pull_repo_if_safe
  pull_machines_repo_if_safe
  check_keychain_runtime
  require_keychain_identity
  archive="$(secrets_archive_for "$from_machine")"
  [[ -f "$archive" ]] || {
    error "missing encrypted secrets snapshot: $archive"
    exit 1
  }

  tmp_identity="$(mktemp "${TMPDIR:-/tmp}/mac-sync-age-identity.XXXXXX")"
  MAC_SYNC_SECRET_IDENTITY_TMP="$tmp_identity"
  trap 'cleanup_secret_identity_tmp' EXIT INT TERM
  write_keychain_identity_file "$tmp_identity"
  age -d -i "$tmp_identity" "$archive" | gtar -tzf -
  cleanup_secret_identity_tmp
  trap - EXIT INT TERM
}


# Restore files from an encrypted secrets archive.
cmd_secrets_restore() {
  local force=0
  local from_machine="$MACHINE_NAME"
  local archive
  local tmp_conflicts
  local tmp_entries
  local tmp_identity

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --from)
        if [[ "$#" -lt 2 ]]; then
          error "missing machine name after --from"
          exit 2
        fi
        from_machine="$2"
        shift 2
        ;;
      --force)
        force=1
        shift
        ;;
      *)
        error "unknown secrets restore option: $1"
        exit 2
        ;;
    esac
  done

  safe_machine_name "$from_machine" || {
    error "invalid machine name: $from_machine"
    exit 2
  }

  check_runtime
  pull_repo_if_safe
  pull_machines_repo_if_safe
  check_keychain_runtime
  require_keychain_identity
  archive="$(secrets_archive_for "$from_machine")"
  [[ -f "$archive" ]] || {
    error "missing encrypted secrets snapshot: $archive"
    exit 1
  }

  tmp_conflicts="$(mktemp "${TMPDIR:-/tmp}/mac-sync-secret-conflicts.XXXXXX")"
  tmp_entries="$(mktemp "${TMPDIR:-/tmp}/mac-sync-secret-entries.XXXXXX")"
  tmp_identity="$(mktemp "${TMPDIR:-/tmp}/mac-sync-age-identity.XXXXXX")"
  MAC_SYNC_SECRET_CONFLICTS_TMP="$tmp_conflicts"
  MAC_SYNC_SECRET_ENTRIES_TMP="$tmp_entries"
  MAC_SYNC_SECRET_IDENTITY_TMP="$tmp_identity"
  trap 'cleanup_secret_restore_tmps' EXIT INT TERM

  write_keychain_identity_file "$tmp_identity"
  write_secret_archive_entries "$archive" "$tmp_identity" "$tmp_entries"
  validate_archive_entries "$tmp_entries"
  secret_restore_conflicts "$tmp_entries" >"$tmp_conflicts"

  if [[ "$force" != "1" && -s "$tmp_conflicts" ]]; then
    error "secret restore would overwrite existing files; re-run with --force"
    sed 's/^/  /' "$tmp_conflicts" >&2
    exit 1
  fi

  if [[ "$DRY_RUN" = "1" ]]; then
    info "would restore encrypted secrets from: $archive"
    cleanup_secret_restore_tmps
    trap - EXIT INT TERM
    return 0
  fi

  info "restoring encrypted secrets from: $archive"
  age -d -i "$tmp_identity" "$archive" | gtar -xzf - -C "$HOME_DIR"

  cleanup_secret_restore_tmps
  trap - EXIT INT TERM
}


# Test Keychain identity and optional current-machine archive decryption.
cmd_secrets_test() {
  local archive="$SECRETS_ARCHIVE"
  local recipient
  local tmp_identity

  check_runtime
  pull_repo_if_safe
  pull_machines_repo_if_safe
  check_keychain_runtime
  require_keychain_identity

  tmp_identity="$(mktemp "${TMPDIR:-/tmp}/mac-sync-age-identity.XXXXXX")"
  MAC_SYNC_SECRET_IDENTITY_TMP="$tmp_identity"
  trap 'cleanup_secret_identity_tmp' EXIT INT TERM
  write_keychain_identity_file "$tmp_identity"
  recipient="$(recipient_from_identity_file "$tmp_identity")"

  if recipient_configured "$recipient"; then
    info "Keychain identity has a configured public recipient."
  else
    warning "Keychain identity recipient is not in $AGE_RECIPIENTS_FILE"
  fi

  if [[ -f "$archive" ]]; then
    age -d -i "$tmp_identity" "$archive" | gtar -tzf - >/dev/null
    info "Current machine encrypted secrets snapshot can be decrypted."
  else
    info "No current machine encrypted secrets snapshot found yet."
  fi

  cleanup_secret_identity_tmp
  trap - EXIT INT TERM
}


# Sync encrypted secrets and push the machine snapshot.
cmd_secrets_sync() {
  check_runtime
  acquire_lock
  trap 'release_lock' EXIT INT TERM

  pull_repo_if_safe
  pull_machines_repo_if_safe
  sync_secrets_archive required
  commit_and_push

  release_lock
  trap - EXIT INT TERM
}


# Dispatch encrypted secrets subcommands.
cmd_secrets() {
  local command="${1:-help}"

  case "$command" in
    init)
      shift || true
      if [[ "$#" -gt 0 ]]; then
        error "secrets init does not accept options"
        exit 2
      fi
      cmd_secrets_init
      ;;
    sync)
      shift || true
      if [[ "$#" -gt 0 ]]; then
        error "secrets sync does not accept options"
        exit 2
      fi
      cmd_secrets_sync
      ;;
    list)
      shift || true
      cmd_secrets_list "$@"
      ;;
    restore)
      shift || true
      cmd_secrets_restore "$@"
      ;;
    test)
      shift || true
      if [[ "$#" -gt 0 ]]; then
        error "secrets test does not accept options"
        exit 2
      fi
      cmd_secrets_test
      ;;
    help|-h|--help)
      usage_secrets
      ;;
    *)
      error "unknown secrets command: $command"
      exit 2
      ;;
  esac
}


# Print changed files reported by rsync for a directory sync.
print_synced_directory_changes() {
  local src_root="$1"
  local dest_root="$2"
  local changes="$3"
  local sync_label="$4"
  local remove_label="$5"
  local code
  local rel
  local line

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" ]] || continue

    code="${line%%[[:space:]]*}"
    rel="${line#"$code"}"
    rel="${rel#"${rel%%[![:space:]]*}"}"
    [[ -n "$rel" && "$rel" != "." && "$rel" != "./" ]] || continue

    if [[ "$code" == "*deleting" ]]; then
      progress_done "${remove_label}: ${dest_root%/}/$rel"
      continue
    fi

    [[ "${code:1:1}" != "d" ]] || continue
    progress_done "${sync_label}: ${src_root%/}/$rel -> ${dest_root%/}/$rel"
  done <<<"$changes"
}


# Copy one configured path into the machine snapshot.
sync_one_path() {
  local rel="$1"
  local src
  local dest
  local parent
  local changes

  src="$(source_path_for "$rel")"
  dest="$(dest_path_for "$rel")"
  parent="$(dirname "$dest")"

  if [[ ! -e "$src" ]]; then
    if [[ -e "$dest" ]]; then
      if [[ "$DRY_RUN" = "1" ]]; then
        progress_pending "would remove missing source snapshot: $dest"
      else
        rm -rf "$dest"
        progress_done "removed missing source snapshot: $dest"
      fi
    else
      return 0
    fi
    return 0
  fi

  if [[ "$DRY_RUN" = "1" ]]; then
    if [[ -d "$src" ]]; then
      progress_pending "would sync directory: $src -> $dest"
    else
      progress_pending "would sync file: $src -> $dest"
    fi
    return 0
  fi

  mkdir -p "$parent"

  if [[ -d "$src" ]]; then
    mkdir -p "$dest"
    set -- -a --delete --itemize-changes "--out-format=%i %n"
    if [[ -f "$EXCLUDES_FILE" ]]; then
      set -- "$@" "--exclude-from=$EXCLUDES_FILE"
    fi
    changes="$(rsync "$@" "$src/" "$dest/")"
    print_synced_directory_changes "$src" "$dest" "$changes" "sync file" "removed snapshot path"
  else
    set -- -aL --itemize-changes "--out-format=%i %n"
    if [[ -f "$EXCLUDES_FILE" ]]; then
      set -- "$@" "--exclude-from=$EXCLUDES_FILE"
    fi
    changes="$(rsync "$@" "$src" "$dest")"
    if [[ -n "$changes" ]]; then
      progress_done "sync file: $src -> $dest"
    fi
  fi
}


# Restore one configured path from a machine snapshot into HOME.
restore_one_path() {
  local machine="$1"
  local rel="$2"
  local force="$3"
  local src
  local dest
  local parent

  src="$(snapshot_path_for "$machine" "$rel")"
  dest="$(source_path_for "$rel")"
  parent="$(dirname "$dest")"

  if [[ ! -e "$src" && ! -L "$src" ]]; then
    info "skip missing snapshot path: $src"
    return 0
  fi

  if [[ -d "$src" ]]; then
    if [[ -e "$dest" && ! -d "$dest" ]]; then
      if [[ "$force" = "1" ]]; then
        if [[ "$DRY_RUN" = "1" ]]; then
          info "would replace non-directory with directory: $dest"
        else
          rm -f "$dest"
          info "removed non-directory before directory restore: $dest"
        fi
      else
        warning "skip directory restore over non-directory: $dest"
        return 0
      fi
    fi

    if [[ "$DRY_RUN" = "1" ]]; then
      info "would restore directory: $src -> $dest"
      return 0
    else
      mkdir -p "$dest"
      info "restore directory: $src -> $dest"
    fi
    set -- -a
    if [[ "$force" != "1" ]]; then
      set -- "$@" --update
    fi
    if [[ -f "$EXCLUDES_FILE" ]]; then
      set -- "$@" "--exclude-from=$EXCLUDES_FILE"
    fi
    rsync "$@" "$src/" "$dest/"
    return 0
  fi

  if [[ -d "$dest" ]]; then
    if [[ "$force" = "1" ]]; then
      if [[ "$DRY_RUN" = "1" ]]; then
        info "would replace directory with file: $dest"
      else
        rm -rf "$dest"
        info "removed directory before file restore: $dest"
      fi
    else
      warning "skip file restore over directory: $dest"
      return 0
    fi
  fi

  if [[ "$force" != "1" && -e "$dest" && "$dest" -nt "$src" ]]; then
    info "skip newer local file: $dest"
    return 0
  fi

  if [[ "$force" != "1" && -e "$dest" ]] && cmp -s "$src" "$dest"; then
    info "unchanged local file: $dest"
    return 0
  fi

  if [[ "$DRY_RUN" = "1" ]]; then
    info "would restore file: $src -> $dest"
    return 0
  fi

  mkdir -p "$parent"
  info "restore file: $src -> $dest"
  set -- -a
  if [[ -f "$EXCLUDES_FILE" ]]; then
    set -- "$@" "--exclude-from=$EXCLUDES_FILE"
  fi
  rsync "$@" "$src" "$dest"
}


# Write stable machine metadata that is useful when browsing the repo.
write_machine_metadata() {
  local target="${MACHINE_DIR}/MACHINE.md"
  local computer_name=""
  local local_host_name=""
  local os_name=""
  local os_version=""
  local arch=""

  if command -v scutil >/dev/null 2>&1; then
    computer_name="$(scutil --get ComputerName 2>/dev/null || true)"
    local_host_name="$(scutil --get LocalHostName 2>/dev/null || true)"
  fi

  if command -v sw_vers >/dev/null 2>&1; then
    os_name="$(sw_vers -productName 2>/dev/null || true)"
    os_version="$(sw_vers -productVersion 2>/dev/null || true)"
  fi

  arch="$(uname -m 2>/dev/null || true)"

  mkdir -p "$MACHINE_DIR"
  {
    printf '# %s\n\n' "$MACHINE_NAME"
    printf "This directory contains the curated dotfile snapshot for \`%s\`.\n\n" "$MACHINE_NAME"
    printf '%s\n' "- ComputerName: \`${computer_name:-unknown}\`"
    printf '%s\n' "- LocalHostName: \`${local_host_name:-unknown}\`"
    printf '%s\n' "- OS: \`${os_name:-unknown} ${os_version:-unknown}\`"
    printf '%s\n' "- Architecture: \`${arch:-unknown}\`"
  } >"$target"
}


# Pull a git repo when it is safe to fast-forward.
pull_git_repo_if_safe() {
  local repo="$1"
  local label="$2"
  local output

  if ! repo_has_origin "$repo"; then
    warning "no origin remote configured for ${label}; skipping git pull"
    return 0
  fi

  if ! repo_clean "$repo"; then
    warning "${label} has local changes; skipping pre-operation git pull"
    return 0
  fi

  if ! run_with_spinner "pulling latest ${label} changes" git -C "$repo" pull --ff-only; then
    print_progress_command_output
    return 1
  fi

  output="$PROGRESS_COMMAND_OUTPUT"
  case "$output" in
    *"Already up to date."*)
      progress_done "${label} already up to date"
      ;;
    *)
      progress_done "pulled latest ${label} changes"
      ;;
  esac
}


# Pull the mac-sync repo when safe, keeping the installed command in step.
pull_repo_if_safe() {
  pull_git_repo_if_safe "$REPO_DIR" "local repo"
  update_installed_commands_or_exit
}


# Pull the machine snapshot repo when safe.
pull_machines_repo_if_safe() {
  pull_git_repo_if_safe "$MACHINES_REPO_DIR" "machines repo"
}


# Print the spinner helper source path to install when one is available.
spinner_source_path() {
  local path

  for path in "$REPO_SPINNER" "$SELF_SPINNER"; do
    if [[ -f "$path" ]]; then
      printf '%s\n' "$path"
      return 0
    fi
  done

  return 1
}


# Install or refresh the spinner helper command.
install_spinner_command() {
  local source

  if ! source="$(spinner_source_path)"; then
    warning "spinner helper not found; skipping install: $REPO_SPINNER"
    return 0
  fi

  install -m 755 "$source" "$SPINNER_INSTALL_PATH"
}


# Update installed helper commands from the repo copy when needed.
update_installed_spinner() {
  local source

  source="$(spinner_source_path)" || return 0
  if [[ -f "$SPINNER_INSTALL_PATH" ]] && cmp -s "$source" "$SPINNER_INSTALL_PATH"; then
    return 0
  fi

  mkdir -p "$INSTALL_DIR"
  install -m 755 "$source" "$SPINNER_INSTALL_PATH"
  log "updated installed spinner helper from $source"
}


# Update installed helper commands, exiting when the running mac-sync changed.
update_installed_commands_or_exit() {
  update_installed_spinner
  update_installed_self_or_exit
}


# Update the installed script from the repo copy when a pull changed it.
update_installed_self_or_exit() {
  local self_real
  local install_real

  if [[ ! -f "$REPO_SCRIPT" ]]; then
    return 0
  fi

  if [[ ! -f "$INSTALL_PATH" ]]; then
    return 0
  fi

  if cmp -s "$REPO_SCRIPT" "$INSTALL_PATH"; then
    return 0
  fi

  self_real="$(realpath_existing "$SELF_PATH")"
  install_real="$(realpath_existing "$INSTALL_PATH")"

  if [[ "$self_real" != "$install_real" ]]; then
    return 0
  fi

  install -m 755 "$REPO_SCRIPT" "$INSTALL_PATH"
  warning "mac-sync updated itself from $REPO_SCRIPT"
  warning "Please re-run the sync using the new script: $INSTALL_PATH sync"
  log "self-updated installed script from repo and exited before continuing"
  exit 75
}


# Commit the machine snapshot when it changed and push it to origin.
commit_and_push() {
  local branch
  local commit_message
  local committed=0

  if [[ "$DRY_RUN" = "1" ]]; then
    progress_pending "dry run enabled; skipping git commit and push"
    return 0
  fi

  if ! run_with_spinner \
    "checking machine snapshot changes" \
    git -C "$MACHINES_REPO_DIR" add "machines/${MACHINE_NAME}"; then
    print_progress_command_output
    return 1
  fi

  if git -C "$MACHINES_REPO_DIR" diff --cached --quiet -- "machines/${MACHINE_NAME}"; then
    progress_done "no machine snapshot changes to commit"
  else
    commit_message="chore(${MACHINE_NAME}): sync machine state"
    if ! run_with_spinner \
      "committing machine snapshot changes" \
      git -C "$MACHINES_REPO_DIR" commit -m "$commit_message" -- "machines/${MACHINE_NAME}"; then
      print_progress_command_output
      return 1
    fi
    progress_done "committed machine snapshot changes"
    committed=1
  fi

  if ! repo_has_origin "$MACHINES_REPO_DIR"; then
    warning "no origin remote configured for machines repo; skipping git push"
    return 0
  fi

  branch="$(git -C "$MACHINES_REPO_DIR" branch --show-current)"
  if [[ -z "$branch" ]]; then
    warning "detached HEAD; skipping git push"
    return 0
  fi

  if [[ "$committed" = "0" ]] && ! branch_ahead_of_upstream "$MACHINES_REPO_DIR"; then
    progress_done "no local commits to push"
    return 0
  fi

  if repo_clean "$MACHINES_REPO_DIR" && branch_has_upstream "$MACHINES_REPO_DIR"; then
    if ! run_with_spinner \
      "rebasing machines repo before push" \
      git -C "$MACHINES_REPO_DIR" pull --rebase --autostash; then
      print_progress_command_output
      return 1
    fi
    progress_done "rebased machines repo before push"
  elif repo_clean "$MACHINES_REPO_DIR"; then
    progress_done "no upstream branch yet; skipping pre-push pull"
  else
    warning "machines repo still has local changes outside this machine snapshot; pushing current branch without rebasing"
  fi

  if ! run_with_spinner \
    "pushing ${branch} to origin" \
    git -C "$MACHINES_REPO_DIR" push -u origin "$branch"; then
    print_progress_command_output
    return 1
  fi
  progress_done "pushed ${branch} to origin"
}


# Ensure the repo and runtime commands are available.
check_runtime() {
  need comm
  need find
  need git
  need rsync
  need sed
  need awk
  need sort
  need wc

  if [[ ! -d "$REPO_DIR/.git" ]]; then
    error "not a git repository: $REPO_DIR"
    error "clone or create the repo there, or set MAC_SYNC_REPO"
    exit 1
  fi

  if [[ ! -d "$MACHINES_REPO_DIR/.git" ]]; then
    error "not a git repository: $MACHINES_REPO_DIR"
    error "clone https://github.com/stephenlclarke/dot-files there, or set MAC_SYNC_MACHINES_REPO"
    exit 1
  fi
}


# Sync configured paths into the machine directory and push changes.
cmd_sync() {
  local rel
  local tmp_configured
  local tmp_dynamic
  local tmp_dynamic_extra
  local tmp_manifest

  check_runtime
  acquire_lock
  start_sync_status
  trap 'status=$?; progress_stop; finish_sync_status "$status"; cleanup_sync_tmps; release_lock; exit "$status"' EXIT INT TERM

  pull_repo_if_safe
  pull_machines_repo_if_safe
  capture_sync_start_metrics

  tmp_configured="$(mktemp "${TMPDIR:-/tmp}/mac-sync-configured.XXXXXX")"
  tmp_dynamic="$(mktemp "${TMPDIR:-/tmp}/mac-sync-dynamic.XXXXXX")"
  tmp_dynamic_extra="$(mktemp "${TMPDIR:-/tmp}/mac-sync-dynamic-extra.XXXXXX")"
  tmp_manifest="$(mktemp "${TMPDIR:-/tmp}/mac-sync-manifest.XXXXXX")"
  MAC_SYNC_SYNC_TMP_CONFIGURED="$tmp_configured"
  MAC_SYNC_SYNC_TMP_DYNAMIC="$tmp_dynamic"
  MAC_SYNC_SYNC_TMP_DYNAMIC_EXTRA="$tmp_dynamic_extra"
  MAC_SYNC_SYNC_TMP_MANIFEST="$tmp_manifest"
  trap 'progress_stop; cleanup_sync_tmps; release_lock' EXIT INT TERM

  progress_start "building sync manifest"
  configured_manifest_paths >"$tmp_configured"
  dynamic_manifest_paths >"$tmp_dynamic"
  dynamic_extra_paths "$tmp_dynamic" "$tmp_configured" >"$tmp_dynamic_extra"
  awk 'NF && !seen[$0]++' "$tmp_configured" "$tmp_dynamic_extra" >"$tmp_manifest"
  progress_done "built sync manifest"

  if [[ "$DRY_RUN" != "1" ]]; then
    mkdir -p "$MACHINE_HOME_DIR" "$MACHINE_ABSOLUTE_DIR"
  fi

  progress_start "syncing configured paths"
  while IFS= read -r rel; do
    sync_one_path "$rel"
  done <"$tmp_manifest"
  progress_done "synced configured paths"

  prune_stale_dynamic_paths "$tmp_dynamic_extra" "$tmp_configured"
  sync_homebrew_packages
  sync_secrets_archive auto

  if [[ "$DRY_RUN" != "1" ]]; then
    if dynamic_refs_enabled; then
      write_dynamic_paths_manifest "$tmp_dynamic_extra"
    fi
    write_machine_metadata
  fi

  capture_sync_finish_metrics
  cleanup_sync_tmps

  commit_and_push
  finish_sync_status 0
  release_lock
  trap - EXIT INT TERM
}


# Restore a machine snapshot from the repo back into HOME.
cmd_restore() {
  local force=0
  local from_machine="$MACHINE_NAME"
  local machine_dir
  local rel

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --from)
        if [[ "$#" -lt 2 ]]; then
          error "missing machine name after --from"
          exit 2
        fi
        from_machine="$2"
        shift 2
        ;;
      --force)
        force=1
        shift
        ;;
      -h|--help)
        usage_restore
        return 0
        ;;
      *)
        error "unknown restore option: $1"
        usage_restore >&2
        exit 2
        ;;
    esac
  done

  if ! safe_machine_name "$from_machine"; then
    error "invalid machine name: $from_machine"
    exit 2
  fi

  check_runtime
  pull_repo_if_safe
  pull_machines_repo_if_safe

  machine_dir="${MACHINES_ROOT_DIR}/${from_machine}"
  if [[ ! -d "$machine_dir" ]]; then
    error "missing machine snapshot: $machine_dir"
    exit 1
  fi

  info "restoring from machine: $from_machine"
  if [[ "$force" = "1" ]]; then
    warning "force enabled; newer local files may be overwritten"
  else
    info "newer local files will be kept; use --force to overwrite them"
  fi

  while IFS= read -r rel; do
    restore_one_path "$from_machine" "$rel" "$force"
  done < <(restore_manifest_paths "$from_machine")

  print_homebrew_restore_commands "$from_machine"
  print_secrets_restore_hint "$from_machine"
}


# Show configured paths and where they land in the repo.
cmd_list() {
  local rel
  local src
  local dest
  local state

  info "local repo: $REPO_DIR"
  info "machines repo: $MACHINES_REPO_DIR"
  info "machine: $MACHINE_NAME"
  info "paths file: $PATHS_FILE"
  info "dynamic paths file: $DYNAMIC_PATHS_FILE"
  info "Homebrew snapshot dir: $HOMEBREW_DIR"
  info "secret paths file: $SECRET_PATHS_FILE"
  info "age recipients file: $AGE_RECIPIENTS_FILE"
  info "encrypted secrets archive: $SECRETS_ARCHIVE"
  if dynamic_refs_enabled; then
    info "dynamic refs: enabled"
  else
    info "dynamic refs: disabled"
  fi
  if homebrew_sync_enabled; then
    info "Homebrew sync: enabled"
  else
    info "Homebrew sync: disabled"
  fi
  if secrets_sync_enabled; then
    info "encrypted secrets sync: enabled"
  else
    info "encrypted secrets sync: disabled"
  fi
  printf '\n'

  while IFS= read -r rel; do
    src="$(source_path_for "$rel")"
    dest="$(dest_path_for "$rel")"
    if [[ -e "$src" ]]; then
      if [[ -d "$src" ]]; then
        state="dir"
      else
        state="file"
      fi
    else
      state="missing"
    fi
    printf '%-8s %s -> %s\n' "$state" "$src" "$dest"
  done < <(manifest_paths)
}


# Install or refresh the command and its hourly LaunchAgent.
cmd_install() {
  need install
  need launchctl
  validate_int_range "MAC_SYNC_HOURLY_MINUTE" "$HOURLY_MINUTE" 0 59

  mkdir -p "$INSTALL_DIR" "$(dirname "$LAUNCH_AGENT_PLIST")"

  install -m 755 "$SELF_PATH" "$INSTALL_PATH"
  install_spinner_command
  write_launchagent

  launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$LAUNCH_AGENT_PLIST"

  info "installed $INSTALL_PATH"
  info "installed $SPINNER_INSTALL_PATH"
  info "loaded $LAUNCH_AGENT_PLIST"
}


# Uninstall the LaunchAgent and installed command.
cmd_uninstall() {
  launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  rm -f "$LAUNCH_AGENT_PLIST"

  if [[ -e "$INSTALL_PATH" ]]; then
    rm -f "$INSTALL_PATH"
  fi
  if [[ -e "$SPINNER_INSTALL_PATH" ]]; then
    rm -f "$SPINNER_INSTALL_PATH"
  fi

  info "removed $LAUNCH_AGENT_PLIST"
  info "removed $INSTALL_PATH"
  info "removed $SPINNER_INSTALL_PATH"
}


# Write the hourly LaunchAgent plist.
write_launchagent() {
  local escaped_install_path
  local escaped_log_err
  local escaped_log_out
  local escaped_machine_name
  local escaped_machines_repo_dir
  local escaped_path
  local escaped_repo_dir
  local escaped_script_colour
  local script_colour_xml=""

  escaped_install_path="$(xmlescape "$INSTALL_PATH")"
  escaped_log_err="$(xmlescape "$LOG_ERR")"
  escaped_log_out="$(xmlescape "$LOG_OUT")"
  escaped_machine_name="$(xmlescape "$MACHINE_NAME")"
  escaped_machines_repo_dir="$(xmlescape "$MACHINES_REPO_DIR")"
  escaped_path="$(xmlescape "$LAUNCH_AGENT_PATH")"
  escaped_repo_dir="$(xmlescape "$REPO_DIR")"

  if [[ -n "${SCRIPT_COLOUR:-}" ]]; then
    escaped_script_colour="$(xmlescape "$SCRIPT_COLOUR")"
    script_colour_xml="$(cat <<EOF
      <key>SCRIPT_COLOUR</key>
      <string>${escaped_script_colour}</string>
EOF
)"
  fi

  cat >"$LAUNCH_AGENT_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>${LAUNCH_AGENT_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
      <string>${escaped_install_path}</string>
      <string>run</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
      <key>MAC_SYNC_REPO</key>
      <string>${escaped_repo_dir}</string>
      <key>MAC_SYNC_MACHINES_REPO</key>
      <string>${escaped_machines_repo_dir}</string>
      <key>MAC_SYNC_MACHINE</key>
      <string>${escaped_machine_name}</string>
      <key>PATH</key>
      <string>${escaped_path}</string>
${script_colour_xml}
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>StartCalendarInterval</key>
    <dict>
      <key>Minute</key>
      <integer>${HOURLY_MINUTE}</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>${escaped_log_out}</string>
    <key>StandardErrorPath</key>
    <string>${escaped_log_err}</string>
  </dict>
</plist>
EOF
}


# Print one value from the local sync status file.
sync_status_value() {
  local key="$1"

  [[ -f "$SYNC_STATUS_FILE" ]] || return 0
  awk -F= -v key="$key" '
    $1 == key {
      sub(/^[^=]*=/, "")
      print
      exit
    }
  ' "$SYNC_STATUS_FILE"
}


# Print captured messages from the last sync run.
print_status_messages() {
  local title="$1"
  local file="$2"

  if [[ -s "$file" ]]; then
    info "$title:"
    sed 's/^/  /' "$file"
  else
    info "$title: none"
  fi
}


# Print local git worktree changes with a heading when any exist.
print_repo_local_changes() {
  local repo="$1"
  local title="$2"
  local changes

  changes="$(git -C "$repo" status --short 2>/dev/null || true)"
  if [[ -z "$changes" ]]; then
    return 0
  fi

  info "${title} local changes:"
  sed 's/^/  /' <<<"$changes"
}


# Return the LaunchAgent minute from the installed plist when available.
launchagent_scheduled_minute() {
  local minute=""

  if [[ -f "$LAUNCH_AGENT_PLIST" ]]; then
    minute="$(awk '
      /<key>Minute<\/key>/ { want = 1; next }
      want && /<integer>/ {
        line = $0
        sub(/^.*<integer>[[:space:]]*/, "", line)
        sub(/[[:space:]]*<\/integer>.*$/, "", line)
        print line
        exit
      }
    ' "$LAUNCH_AGENT_PLIST")"
  fi

  case "$minute" in
    ""|*[!0-9]*)
      minute="$HOURLY_MINUTE"
      ;;
  esac
  case "$minute" in
    ""|*[!0-9]*)
      minute=0
      ;;
  esac

  if (( 10#$minute < 0 || 10#$minute > 59 )); then
    minute=0
  fi

  printf '%s\n' "$minute"
}


# Format an epoch timestamp on macOS or GNU date.
format_epoch() {
  local epoch="$1"

  date -r "$epoch" '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null \
    || date -d "@$epoch" '+%Y-%m-%d %H:%M:%S %Z'
}


# Print the next hourly LaunchAgent run based on the configured minute.
next_scheduled_run() {
  local current_minute
  local current_second
  local delta
  local elapsed
  local next_epoch
  local now_epoch
  local scheduled_minute
  local target

  scheduled_minute="$(launchagent_scheduled_minute)"
  now_epoch="$(date '+%s')"
  current_minute="$(date '+%M')"
  current_second="$(date '+%S')"

  ((elapsed = 10#$current_minute * 60 + 10#$current_second)) || true
  ((target = 10#$scheduled_minute * 60)) || true
  if (( elapsed < target )); then
    ((delta = target - elapsed)) || true
  else
    ((delta = 3600 - elapsed + target)) || true
  fi
  ((next_epoch = now_epoch + delta)) || true

  format_epoch "$next_epoch"
}


# Show current repo, launchd, and git state.
cmd_status() {
  local duration
  local error_count
  local finished_at
  local last_commit
  local live_byte_count
  local live_file_count
  local net_byte_change
  local remote_repo
  local result
  local updated_byte_count
  local updated_file_count
  local warning_count

  info "local repo: $REPO_DIR"
  info "machines repo: $MACHINES_REPO_DIR"
  info "machine: $MACHINE_NAME"
  info "installed command: $INSTALL_PATH"
  info "spinner command: $SPINNER_INSTALL_PATH"
  info "paths file: $PATHS_FILE"
  info "LaunchAgent: $LAUNCH_AGENT_PLIST"
  info "status file: $SYNC_STATUS_FILE"
  info "stdout log: $LOG_OUT"
  info "stderr log: $LOG_ERR"

  if [[ -x "$INSTALL_PATH" ]]; then
    info "install state: installed"
  else
    info "install state: not installed"
  fi

  if launchagent_loaded; then
    info "LaunchAgent state: loaded"
  else
    info "LaunchAgent state: not loaded"
  fi
  info "next scheduled run: $(next_scheduled_run)"

  live_file_count="$(tree_file_count "$MACHINE_DIR")"
  live_byte_count="$(tree_byte_count "$MACHINE_DIR")"
  info "machine snapshot stored: ${live_byte_count} bytes across ${live_file_count} files"

  if [[ -f "$SYNC_STATUS_FILE" ]]; then
    result="$(sync_status_value result)"
    finished_at="$(sync_status_value finished_at)"
    duration="$(sync_status_value duration_seconds)"
    updated_file_count="$(sync_status_value updated_file_count)"
    updated_byte_count="$(sync_status_value updated_byte_count)"
    net_byte_change="$(sync_status_value net_byte_change)"
    warning_count="$(sync_status_value warning_count)"
    error_count="$(sync_status_value error_count)"
    remote_repo="$(sync_status_value remote_repo)"
    if [[ -z "$remote_repo" ]]; then
      remote_repo="$(git -C "$MACHINES_REPO_DIR" remote get-url origin 2>/dev/null || printf 'unknown')"
    fi
    last_commit="$(sync_status_value last_commit)"

    info "last sync: ${result:-unknown}"
    info "last sync finished: ${finished_at:-unknown}"
    info "last sync duration: ${duration:-0}s"
    info "last sync updated: ${updated_byte_count:-0} bytes across ${updated_file_count:-0} files"
    info "last sync net storage change: ${net_byte_change:-0} bytes"
    info "last sync warnings: ${warning_count:-0}"
    print_status_messages "last sync warning messages" "$SYNC_WARNINGS_FILE"
    info "last sync errors: ${error_count:-0}"
    print_status_messages "last sync error messages" "$SYNC_ERRORS_FILE"
    info "last sync remote repo: ${remote_repo:-unknown}"
    info "last sync commit: ${last_commit:-unknown}"
  else
    info "last sync: unknown (no local status file yet)"
  fi

  if [[ -d "$REPO_DIR/.git" ]]; then
    info "local repo branch: $(git -C "$REPO_DIR" branch --show-current 2>/dev/null || true)"
    print_repo_local_changes "$REPO_DIR" "local repo"
  else
    warning "local repo is not initialized yet"
  fi

  if [[ -d "$MACHINES_REPO_DIR/.git" ]]; then
    info "machines repo branch: $(git -C "$MACHINES_REPO_DIR" branch --show-current 2>/dev/null || true)"
    print_repo_local_changes "$MACHINES_REPO_DIR" "machines repo"
  else
    warning "machines repo is not initialized yet"
  fi
}


# Dispatch the requested command.
main() {
  local command="${1:-help}"

  case "$command" in
    install|bootstrap)
      cmd_install
      ;;
    uninstall)
      cmd_uninstall
      ;;
    sync|run)
      cmd_sync
      ;;
    restore)
      shift || true
      cmd_restore "$@"
      ;;
    secrets)
      shift || true
      cmd_secrets "$@"
      ;;
    list|paths)
      cmd_list
      ;;
    status)
      cmd_status
      ;;
    help|-h|--help)
      shift || true
      cmd_help "$@"
      ;;
    *)
      error "unknown command: $command"
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"

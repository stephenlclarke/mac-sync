# List the VS Code extension snapshot for a machine.
cmd_editor_list() {
  local from_machine="$MACHINE_NAME"
  local snapshot_file

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --from)
        if [[ "$#" -lt 2 ]]; then
          error "missing machine name after --from"
          exit 2
        fi
        from_machine="$2"
        shift 2
        ;;
      *)
        error "unknown editor list option: $1"
        exit 2
        ;;
    esac
  done

  check_runtime
  pull_machines_repo_if_safe
  from_machine="$(resolve_requested_machine "$from_machine")"
  snapshot_file="$(vscode_extensions_file_for "$from_machine")"
